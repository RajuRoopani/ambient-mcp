{
  "manifest_version": 3,
  "name": "Ambient MCP",
  "version": "1.0.0",
  "description": "Your browser becomes your AI's memory. Captures browsing history, auth tokens, and page context — streams everything to a local MCP server so AI agents have full awareness of your daily work.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "notifications",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Ambient MCP",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
